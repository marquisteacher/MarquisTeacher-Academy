rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── USERS ──────────────────────────────────────────────
    // Students read/write only their own profile
    // Teachers can read all student profiles
    match /users/{userId} {
      allow read:  if request.auth != null &&
                      (request.auth.uid == userId || isTeacher());
      allow write: if request.auth != null &&
                      request.auth.uid == userId;
    }

    // ── MESSAGES ───────────────────────────────────────────
    // Any logged-in user can read messages
    // Users can only create messages with their own uid
    match /messages/{msgId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null &&
                       request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── CONTACT SUBMISSIONS (existing collection) ──────────
    // Keep your existing contactSubmissions rules intact
    match /contactSubmissions/{docId} {
      allow read:  if isTeacher();
      allow create: if true; // public contact form
      allow update, delete: if false;
    }

    // ── EXAM BOARD (existing collection) ──────────────────
    match /examBoard/{docId} {
      allow read:  if request.auth != null;
      allow write: if isTeacher();
    }

    // ── HELPER FUNCTION ────────────────────────────────────
    function isTeacher() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }
  }
}
